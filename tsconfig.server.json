{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "rootDir": ".",
    "outDir": "dist",
    "types": ["node"],
    "jsx": "react-jsx"
  },
  "include": ["src/server/**/*.ts", "src/music/**/*.ts", "src/lavalink/**/*.ts", "src/config/**/*.ts", "src/types/**/*.ts", "scripts/**/*.ts"]
}
